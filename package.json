{
  "name": "kingdom-of-christ-ministries-monorepo",
  "version": "1.0.0",
  "description": "Professional Church Web Application with AI Features",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev -w frontend",
    "build": "npm run build -w frontend",
    "start": "npm run start -w frontend",
    "lint": "npm run lint -w frontend",
    "postinstall": "npm run db:generate -w backend",
    "db:seed": "npm run db:seed -w backend",
    "db:check": "npm run db:check -w backend",
    "db:push": "npm run db:push -w backend",
    "db:generate": "npm run db:generate -w backend",
    "db:studio": "npm run db:studio -w backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
