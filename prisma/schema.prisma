generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  emailVerified      DateTime?
  image              String?
  password           String
  role               UserRole            @default(MEMBER)
  phone              String?
  address            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  donations          Donation[]
  eventRegistrations EventRegistration[]
  prayerRequests     PrayerRequest[]
  testimonials       Testimonial[]
}

model Event {
  id            String              @id @default(cuid())
  title         String
  description   String
  date          DateTime
  time          String
  location      String
  image         String?
  category      EventCategory
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  registrations EventRegistration[]
}

model EventRegistration {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Sermon {
  id          String   @id @default(cuid())
  title       String
  description String
  pastor      String
  date        DateTime
  videoUrl    String?
  audioUrl    String?
  transcript  String?
  thumbnail   String?
  category    String
  tags        String[]
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
}

model PrayerRequest {
  id          String         @id @default(cuid())
  userId      String
  title       String
  description String
  category    PrayerCategory
  isAnonymous Boolean        @default(false)
  status      PrayerStatus   @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Donation {
  id                String          @id @default(cuid())
  userId            String?
  amount            Float
  currency          String          @default("INR")
  purpose           DonationPurpose
  paymentMethod     String
  stripeId          String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  donorName         String?
  donorEmail        String?
  donorPhone        String?
  status            DonationStatus  @default(PENDING)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User?           @relation(fields: [userId], references: [id])
}

model Announcement {
  id        String    @id @default(cuid())
  title     String
  content   String
  priority  Priority  @default(NORMAL)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  userId    String
  content   String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ministry {
  id          String   @id @default(cuid())
  name        String
  description String
  leader      String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pastor {
  id        String   @id @default(cuid())
  name      String
  title     String
  bio       String
  image     String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Gallery {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  content   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model ChurchSettings {
  id                         String   @id @default("settings")
  churchName                 String
  tagline                    String
  primaryEmail               String
  contactPhone               String
  address                    String
  worshipServices            String
  bilingualSupport           Boolean  @default(true)
  visitorRegistrationEnabled Boolean  @default(true)
  updatedAt                  DateTime @updatedAt
}

model MemberRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  type      String
  time      String
  status    String   @default("New")
  avatar    String?
  createdAt DateTime @default(now())
}

model SmallGroup {
  id            String   @id @default(cuid())
  name          String
  leader        String
  location      String
  meetingTime   String
  attendanceAvg Int      @default(0)
  createdAt     DateTime @default(now())
}

model Volunteer {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  ministry  String
  status    String   @default("Pending")
  appliedAt String
  createdAt DateTime @default(now())
}

model BibleStudy {
  id           String   @id @default(cuid())
  name         String
  leader       String
  time         String
  membersCount Int      @default(0)
  day          String
  createdAt    DateTime @default(now())
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  PASTOR
  MEMBER
}

enum EventCategory {
  WORSHIP
  PRAYER
  YOUTH
  CHILDREN
  WOMEN
  MEN
  SPECIAL
}

enum PrayerCategory {
  HEALTH
  FAMILY
  FINANCIAL
  SPIRITUAL
  GUIDANCE
  THANKSGIVING
  OTHER
}

enum PrayerStatus {
  PENDING
  PRAYING
  ANSWERED
}

enum DonationPurpose {
  GENERAL
  BUILDING
  MISSIONS
  YOUTH
  CHARITY
  TITHE
  OFFERING
  OTHER
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model AttendanceRecord {
  id          String   @id @default(cuid())
  date        DateTime
  serviceType String
  location    String
  headcount   Int
  newVisitors Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pledge {
  id              String       @id @default(cuid())
  donorName       String
  donorEmail      String
  committedAmount Float
  paidAmount      Float        @default(0)
  targetDate      DateTime
  purpose         String
  status          PledgeStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum PledgeStatus {
  PENDING
  ACTIVE
  FULFILLED
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Float
  category    String
  description String
  date        DateTime        @default(now())
  account     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum TransactionType {
  INFLOW
  OUTFLOW
}

model Account {
  id          String   @id @default(cuid())
  name        String   @unique
  balance     Float    @default(0)
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
