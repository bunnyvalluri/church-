generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  emailVerified      DateTime?
  image              String?
  profilePublicId    String?
  password           String
  role               UserRole            @default(MEMBER)
  phone              String?
  address            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  donations          Donation[]
  eventRegistrations EventRegistration[]
  prayerRequests     PrayerRequest[]
  testimonials       Testimonial[]
  eventReports       EventReport[]
  mediaReports       MediaReport[]
  eventsCreated      Event[]             @relation("EventCreator")
  eventMediaUploads  EventMedia[]        @relation("EventMediaUploader")
  donationSessions   DonationSession[]
  receipts           Receipt[]
  notificationLogs   NotificationLog[]
  auditLogs          AuditLog[]
  deviceTokens       DeviceToken[]
  eventAttendance    EventAttendance[]
  sermonLikes        SermonLike[]
  sermonComments     SermonComment[]
  sermonBookmarks    SermonBookmark[]
  sermonViews        SermonView[]
  sermonDownloads    SermonDownload[]

  @@map("members")
}

model Event {
  id                    String              @id @default(cuid())
  title                 String              // Event Name
  slug                  String              @unique
  shortDescription      String?             @db.Text
  description           String              @db.Text // Full Description
  date                  DateTime            @map("event_date") // Mapped to startDate
  endDate               DateTime?           @map("end_date")
  time                  String              @map("event_time") // start time
  endTime               String?             @map("end_time")
  timezone              String              @default("Asia/Kolkata")
  location              String              // Venue
  googleMapsUrl         String?             @map("google_maps_url")
  category              String              // Mapped as string (Service, Conference, etc.)
  organizer             String?
  speaker               String?
  pastor                String?
  contactPerson         String?             @map("contact_person")
  contactPhone          String?             @map("contact_phone")
  contactEmail          String?             @map("contact_email")
  registrationRequired  Boolean             @default(false) @map("registration_required")
  registrationLimit     Int?                @map("registration_limit")
  remainingSeats        Int?                @map("remaining_seats")
  image                 String?             @map("image_url") // cover image URL
  coverImagePublicId    String?             @map("cover_image_public_id")
  eventBanner           String?             @map("event_banner")
  eventBannerPublicId   String?             @map("event_banner_public_id")
  tags                  String[]            @default([])
  featured              Boolean             @default(false)
  priority              Priority            @default(NORMAL)
  colorTheme            String?             @map("color_theme")
  status                EventStatus         @default(DRAFT)
  visibility            EventVisibility     @default(PUBLIC)
  registrationOpenDate  DateTime?           @map("registration_open_date")
  registrationCloseDate DateTime?           @map("registration_close_date")
  seoTitle              String?             @map("seo_title")
  seoDescription        String?             @map("seo_description")
  isDeleted             Boolean             @default(false) @map("is_deleted")
  deletedAt             DateTime?           @map("deleted_at")
  displayOrder          Int                 @default(0) @map("display_order")
  isPublished           Boolean             @default(false) @map("is_published")
  branchId              String?             @map("branch_id")
  branch                Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdById           String?             @map("created_by")
  createdBy             User?               @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt
  videoUrl              String?             @map("video_url")
  registrations         EventRegistration[]
  media                 EventMedia[]
  eventImages           EventImage[]
  eventVideos           EventVideo[]
  eventAttendance       EventAttendance[]
  eventNotifications    EventNotification[]
  eventReport           EventReport?

  @@index([branchId])
  @@index([createdById])
  @@map("events")
}

model EventMedia {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  imageUrl     String
  publicId     String?  // Cloudinary public_id for deletion
  caption      String?
  uploadedById String?
  uploadedBy   User?    @relation("EventMediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedAt   DateTime @default(now())

  @@index([eventId])
}

model EventImage {
  id           String   @id @default(cuid())
  eventId      String   @map("event_id")
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url          String   @map("image_url")
  publicId     String?  @map("public_id")
  caption      String?
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  @@index([eventId])
  @@map("event_images")
}

model EventVideo {
  id           String   @id @default(cuid())
  eventId      String   @map("event_id")
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url          String   @map("video_url")
  publicId     String?  @map("public_id")
  caption      String?
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  @@index([eventId])
  @@map("event_videos")
}

model EventRegistration {
  id        String            @id @default(cuid())
  userId    String?           @map("user_id") // Nullable for guest registrations
  eventId   String            @map("event_id")
  name      String            // Registrant name
  email     String            // Registrant email
  phone     String?           // Registrant phone
  qrCode    String?           @map("qr_code") // QR ticket contents
  status    String            @default("REGISTERED") // REGISTERED, CANCELLED, WAITLISTED
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendance EventAttendance[]

  @@unique([userId, eventId])
  @@map("event_registrations")
}

enum SermonVisibility {
  PUBLIC
  MEMBERS_ONLY
  PRIVATE
}

enum SermonStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Sermon {
  id                   String             @id @default(cuid())
  title                String
  slug                 String             @unique
  subtitle             String?            @db.Text
  shortDescription     String?            @db.Text
  description          String             @db.Text // Full Description
  bibleVerse           String?            @map("bible_verse")
  book                 String?
  chapter              String?
  verses               String?
  speaker              String
  pastor               String?
  guestSpeaker         String?            @map("guest_speaker")
  branch               String?
  category             String
  language             String             @default("English")
  date                 DateTime           @map("date_preached")
  views                Int                @default(0)
  duration             String?            // e.g. "45:00"
  tags                 String[]           @default([])
  keywords             String[]           @default([])
  thumbnail            String?            @map("thumbnail_url")
  thumbnailPublicId    String?            @map("thumbnail_public_id")
  banner               String?            @map("banner_url")
  bannerPublicId       String?            @map("banner_public_id")
  videoUrl             String?            @map("video_url")
  videoPublicId        String?            @map("video_public_id")
  audioUrl             String?            @map("audio_url")
  audioPublicId        String?            @map("audio_public_id")
  pdfUrl               String?            @map("pdf_url")
  pdfPublicId          String?            @map("pdf_public_id")
  presentationUrl      String?            @map("presentation_url")
  presentationPublicId String?            @map("presentation_public_id")
  transcript           String?            @db.Text
  featured             Boolean            @default(false)
  recommended          Boolean            @default(false)
  visibility           SermonVisibility   @default(PUBLIC)
  status               SermonStatus       @default(DRAFT)
  seoTitle             String?            @map("seo_title")
  seoDescription       String?            @map("seo_description")
  displayOrder         Int                @default(0) @map("display_order")
  isDeleted            Boolean            @default(false) @map("is_deleted")
  deletedAt            DateTime?          @map("deleted_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  createdById          String?            @map("created_by_id")

  // Relations
  media              SermonMedia[]
  audios             SermonAudio[]
  notes              SermonNotes[]
  viewsRelation      SermonView[]
  likes              SermonLike[]
  comments           SermonComment[]
  downloads          SermonDownload[]
  bookmarks          SermonBookmark[]

  @@index([date])
  @@index([category])
  @@index([slug])
  @@index([createdById])
  @@map("sermons")
}

model SermonMedia {
  id        String   @id @default(cuid())
  sermonId  String   @map("sermon_id")
  sermon    Sermon   @relation(fields: [sermonId], references: [id], onDelete: Cascade)
  type      String   // e.g. "VIDEO", "THUMBNAIL", "BANNER"
  url       String
  publicId  String?  @map("public_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sermonId])
  @@map("sermon_media")
}

model SermonAudio {
  id        String   @id @default(cuid())
  sermonId  String   @map("sermon_id")
  sermon    Sermon   @relation(fields: [sermonId], references: [id], onDelete: Cascade)
  url       String
  publicId  String?  @map("public_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sermonId])
  @@map("sermon_audio")
}

model SermonNotes {
  id        String   @id @default(cuid())
  sermonId  String   @map("sermon_id")
  sermon    Sermon   @relation(fields: [sermonId], references: [id], onDelete: Cascade)
  url       String
  publicId  String?  @map("public_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sermonId])
  @@map("sermon_notes")
}

model SermonView {
  id             String   @id @default(cuid())
  sermonId       String   @map("sermon_id")
  sermon         Sermon   @relation(fields: [sermonId], references: [id], onDelete: Cascade)
  userId         String?  @map("user_id")
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  watchTime      Int      @default(0) @map("watch_time")
  completionRate Float    @default(0) @map("completion_rate")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([sermonId])
  @@index([userId])
  @@map("sermon_views")
}

model SermonLike {
  id        String   @id @default(cuid())
  sermonId  String   @map("sermon_id")
  sermon    Sermon   @relation(fields: [sermonId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([sermonId, userId])
  @@map("sermon_likes")
}

model SermonComment {
  id        String   @id @default(cuid())
  sermonId  String   @map("sermon_id")
  sermon    Sermon   @relation(fields: [sermonId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sermonId])
  @@index([userId])
  @@map("sermon_comments")
}

model SermonDownload {
  id        String   @id @default(cuid())
  sermonId  String   @map("sermon_id")
  sermon    Sermon   @relation(fields: [sermonId], references: [id], onDelete: Cascade)
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  fileType  String   @map("file_type")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sermonId])
  @@index([userId])
  @@map("sermon_downloads")
}

model SermonBookmark {
  id        String   @id @default(cuid())
  sermonId  String   @map("sermon_id")
  sermon    Sermon   @relation(fields: [sermonId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([sermonId, userId])
  @@map("sermon_bookmarks")
}

model PrayerRequest {
  id          String         @id @default(cuid())
  userId      String
  title       String
  description String
  category    PrayerCategory
  isAnonymous Boolean        @default(false)
  status      PrayerStatus   @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Donation {
  id                String           @id @default(cuid())
  userId            String?
  amount            Float
  currency          String           @default("INR")
  purpose           String
  purposeId         String?          @map("purpose_id")
  purposeRelation   DonationPurpose? @relation(fields: [purposeId], references: [id])
  branchId          String?          @map("branch_id")
  branch            Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  sessionId         String?          @map("session_id")
  session           DonationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  paymentMethod     String
  stripeId          String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  donorName         String?
  donorEmail        String?
  donorPhone        String?
  status            DonationStatus   @default(PENDING)
  // Security audit fields — set by backend only, never by client
  amountVerified    Boolean          @default(false) @map("amount_verified")
  signatureVerified Boolean          @default(false) @map("signature_verified")
  verifiedBy        String?          @map("verified_by") // WEBHOOK | RAZORPAY_API | DEV_SIMULATION
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  receipt           Receipt?

  @@index([userId])
  @@index([purposeId])
  @@index([branchId])
  @@index([sessionId])
  @@index([razorpayOrderId])
  @@map("donations")
}


model Announcement {
  id        String    @id @default(cuid())
  title     String
  content   String
  priority  Priority  @default(NORMAL)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  userId    String
  content   String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Ministry {
  id          String   @id @default(cuid())
  name        String
  description String
  leader      String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pastor {
  id           String   @id @default(cuid())
  name         String
  title        String
  designation  String?  // e.g. "Senior Pastor", "Associate Pastor"
  bio          String   @db.Text
  image        String?
  imagePublicId String? @map("image_public_id")
  email        String?
  phone        String?
  socialLinks  Json?    @map("social_links") // { facebook, instagram, youtube, twitter }
  branchId     String?  @map("branch_id")
  branch       Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  isActive     Boolean  @default(true) @map("is_active")
  isDeleted    Boolean  @default(false) @map("is_deleted")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([branchId])
  @@index([isActive])
  @@map("pastors")
}

model Gallery {
  id           String   @id @default(cuid())
  title        String
  description  String?
  imageUrl     String   @map("image_url")
  thumbnailUrl String?  @map("thumbnail_url")
  category     String
  branchId     String?  @map("branch_id")
  branch       Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([category])
  @@index([branchId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id               String            @id @default(cuid())
  type             String
  title            String
  content          String
  isRead           Boolean           @default(false)
  link             String?
  createdAt        DateTime          @default(now())
  notificationLogs NotificationLog[]

  @@map("notifications")
}

model ChurchSettings {
  id                         String   @id @default("settings")
  churchName                 String
  tagline                    String
  primaryEmail               String
  contactPhone               String
  address                    String
  worshipServices            String
  bilingualSupport           Boolean  @default(true)
  visitorRegistrationEnabled Boolean  @default(true)
  minDonationAmount          Float    @default(10)
  maxDonationAmount          Float    @default(500000)
  upiId                      String   @default("kcm.kristhraj2004-1@okicici")
  merchantName               String   @default("Kingdom of Christ Ministries")
  qrExpiryMinutes            Int      @default(10)
  updatedAt                  DateTime @updatedAt
}

model MemberRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  type      String
  time      String
  status    String   @default("New")
  avatar    String?
  createdAt DateTime @default(now())
}

model SmallGroup {
  id            String   @id @default(cuid())
  name          String
  leader        String
  location      String
  meetingTime   String
  attendanceAvg Int      @default(0)
  createdAt     DateTime @default(now())
}

model Volunteer {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  ministry  String
  status    String   @default("Pending")
  appliedAt String
  createdAt DateTime @default(now())
}

model BibleStudy {
  id           String   @id @default(cuid())
  name         String
  leader       String
  time         String
  membersCount Int      @default(0)
  day          String
  createdAt    DateTime @default(now())
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  PASTOR
  MEMBER
  EVENT_MANAGER
  FIELD_VOLUNTEER
  NGO_ADMIN
  BRANCH_MANAGER
  MEDIA_TEAM
}



enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
  ARCHIVED
}

enum EventVisibility {
  PUBLIC
  MEMBERS_ONLY
  PRIVATE
}

enum PrayerCategory {
  HEALTH
  FAMILY
  FINANCIAL
  SPIRITUAL
  GUIDANCE
  THANKSGIVING
  OTHER
}

enum PrayerStatus {
  PENDING
  PRAYING
  ANSWERED
}

enum DonationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
  REFUNDED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model AttendanceRecord {
  id          String   @id @default(cuid())
  date        DateTime
  serviceType String
  location    String
  headcount   Int
  newVisitors Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pledge {
  id              String       @id @default(cuid())
  donorName       String
  donorEmail      String
  committedAmount Float
  paidAmount      Float        @default(0)
  targetDate      DateTime
  purpose         String
  status          PledgeStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum PledgeStatus {
  PENDING
  ACTIVE
  FULFILLED
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Float
  category    String
  description String
  date        DateTime        @default(now())
  account     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum TransactionType {
  INFLOW
  OUTFLOW
}

model Account {
  id          String   @id @default(cuid())
  name        String   @unique
  balance     Float    @default(0)
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NgoProject {
  id           String         @id @default(cuid())
  title        String
  description  String
  details      String         @db.Text
  imageUrl     String?        // Cover Image URL
  targetAmount Float?
  raisedAmount Float          @default(0)
  status       String         @default("ACTIVE") // ACTIVE, COMPLETED, PLANNED
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  media        NgoMedia[]
  volunteers   NgoVolunteer[]
}

model NgoMedia {
  id           String      @id @default(cuid())
  title        String?
  description  String?
  type         String      // IMAGE, VIDEO_LOCAL, VIDEO_YOUTUBE
  url          String      // File URL, YouTube embed URL, or local path
  publicId     String?     // Cloudinary asset public ID
  thumbnailUrl String?     // Video preview image
  projectId    String?
  project      NgoProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category     String?     // GANDHI-HOSPITAL, GOVT-HOSPITAL, NIMS-HOSPITAL, BETHANY-SAMRAKSHANA, DISABLED-AASHRAMAM
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model NgoVolunteer {
  id        String      @id @default(cuid())
  name      String
  email     String
  phone     String?
  skills    String?     @db.Text
  status    String      @default("PENDING") // PENDING, APPROVED, REJECTED
  projectId String?
  project   NgoProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Branch {
  id               String            @id @default(cuid())
  name             String            @unique // e.g. "Shapur Nagar", "Subhash Nagar", "Bahadurpally"
  address          String?           @db.Text
  mapsUrl          String?           @map("maps_url")
  serviceHours     String?           @map("service_hours")
  phone            String?
  createdAt        DateTime          @default(now())
  eventReports     EventReport[]
  events           Event[]
  donationSessions DonationSession[]
  donations        Donation[]
  galleryItems     Gallery[]
  churchServices   ChurchService[]
  pastors          Pastor[]

  @@map("branches")
}


model EventReport {
  id                  String        @id @default(cuid())
  branchId            String
  branch              Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  eventId             String?       @unique @map("event_id")
  event               Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  title               String
  description         String        @db.Text
  attendanceCount     Int           @map("attendance_count")
  offeringAmount      Float         @map("offering_amount")
  visitorsCount       Int           @default(0) @map("visitors_count")
  newMembersCount     Int           @default(0) @map("new_members_count")
  prayerRequestsCount Int           @default(0) @map("prayer_requests_count")
  expenses            Float         @default(0)
  comments            String?       @db.Text
  summary             String?       @db.Text
  photos              String[]      @default([])
  videos              String[]      @default([])
  reportDate          DateTime      @map("report_date")
  gpsLocation         String?       @map("gps_location") // Latitude, Longitude string (e.g. "17.4947, 78.4002")
