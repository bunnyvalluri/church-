# ──────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES TEMPLATE (Kingdom of Christ Ministries Web Application)
# Rename this file to `.env.local` and fill in your actual production values.
# DO NOT commit the populated `.env.local` to git version control!
# ──────────────────────────────────────────────────────────────────────────────

# ── 1. Database Configuration (Prisma & PostgreSQL) ───────────────────────────
# Connection string for your PostgreSQL instance (e.g. AWS RDS, Supabase, Neon)
DATABASE_URL="postgresql://user:password@localhost:5432/church_db?schema=public"

# If true, the application bypasses real DB connections and uses local fallback JSONs
DB_OFFLINE="true"

# ── 2. NextAuth Authentication (Optional) ─────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-32-character-secret-key-change-this-in-production"
  
# ── 3. Firebase Client Credentials (REQUIRED for Member Portal Auth) ──────────
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyYourApiKeyHere..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-app-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-app-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-app-id.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789012"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789012:web:a1b2c3d4e5f6g7h8i9"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-MEASUREMENT"

# Firebase Admin SDK (for server-side token verification)
# Generate: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then: node -e "console.log(Buffer.from(require('fs').readFileSync('./serviceAccount.json')).toString('base64'))"
FIREBASE_ADMIN_SERVICE_ACCOUNT=""

# Force offline local JSON simulation for Firestore database writes
FIRESTORE_OFFLINE="true"

# ── 4. Payment Gateways — Razorpay (REQUIRED for donations) ───────────────────
# Live keys: rzp_live_*  |  Test keys: rzp_test_*
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_yourKeyIdHere"
RAZORPAY_KEY_SECRET="yourRazorpayKeySecretHere"

# Razorpay Webhook Secret (CRITICAL — must match Dashboard → Webhooks → Secret)
# Generate: Razorpay Dashboard → Settings → Webhooks → Add/Edit → copy the secret
RAZORPAY_WEBHOOK_SECRET="yourRazorpayWebhookSecretHere"

# UPI Configuration
UPI_ID="kcm.kristhraj2004-1@okicici"
NEXT_PUBLIC_CHURCH_NAME="Kingdom of Christ Ministries"

# Public app URL (used for receipt links, notification URLs)
NEXT_PUBLIC_APP_URL="https://kcmchurch.vercel.app"

# 80G Tax Exemption Registration Number
KCM_80G_REGISTRATION_NO="DIT(E)/80G/HYDTSC/2023-24"

# Admin notification emails (comma-separated)
ADMIN_ALERT_EMAIL="admin@kcmchurch.com,finance@kcmchurch.com"
FINANCE_ALERT_EMAIL="finance@kcmchurch.com"

# Stripe (Optional - for card payments via Razorpay checkout)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_yourKeyHere"
STRIPE_SECRET_KEY="sk_test_yourSecretHere"
STRIPE_WEBHOOK_SECRET="whsec_yourWebhookSecret"

# ── 5. AI Assistant & Embeddings (Language Models) ───────────────────────────
# OpenAI API (For chat assistant and text embeddings)
OPENAI_API_KEY="sk-proj-yourOpenAIKeyHere"

# Gemini API (For secondary fallback assistant)
GEMINI_API_KEY="AIzaSyYourGeminiKeyHere"

# Anthropic API (For Claude LLM assistant)
ANTHROPIC_API_KEY="sk-ant-yourAnthropicKeyHere"

# OpenRouter (Alternative aggregator API)
OPENROUTER_API_KEY="sk-or-yourOpenRouterKeyHere"

# Perplexity (For real-time research grounding)
PERPLEXITY_API_KEY="pplx-yourPerplexityKey"

# ── 6. Vector Database (Pinecone - For Sermon Embeddings Semantic Search) ─────
PINECONE_API_KEY="yourPineconeKey"
PINECONE_ENVIRONMENT="yourPineconeEnvironment"
PINECONE_INDEX="church-sermons"

# ── 7. External Communications — Donations (SMS, Email, WhatsApp) ─────────────

# Resend API (REQUIRED for donation receipt emails and admin notifications)
# Get key: https://resend.com → API Keys
RESEND_API_KEY="re_yourResendKeyHere"
# From email address (must be verified domain in Resend)
RESEND_FROM_EMAIL="receipts@kcmchurch.com"

# Twilio SMS (for donor confirmation SMS)
TWILIO_ACCOUNT_SID="ACyourAccountSidHere"
TWILIO_AUTH_TOKEN="yourAuthTokenHere"
TWILIO_PHONE="+1234567890"

# Twilio WhatsApp Business (for WhatsApp donation receipts)
# Format: whatsapp:+14155238886 (Twilio sandbox) or your approved number
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Fast2SMS (India — alternative to Twilio, affordable SMS)
# Get key: https://www.fast2sms.com → API
FAST2SMS_API_KEY="yourFast2SmsApiKey"

# MSG91 (India enterprise SMS)
MSG91_AUTH_KEY="yourMsg91AuthKey"
MSG91_SENDER_ID="KCMCHURCH"

# ── 8. Church Branding & Metadata ─────────────────────────────────────────────
NEXT_PUBLIC_CHURCH_NAME="Kingdom of Christ Ministries"
NEXT_PUBLIC_CHURCH_ADDRESS="15-201, Vivekananda Nagar, Srinivas Nagar, Jeedimetla, Hyderabad, Telangana 500055"
NEXT_PUBLIC_CHURCH_PHONE="+91 97040 90069"
NEXT_PUBLIC_CHURCH_EMAIL="kingofchristministries23@gmail.com"

# ── 9. Cloudinary Media Storage ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
