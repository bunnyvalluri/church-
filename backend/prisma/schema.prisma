generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  emailVerified      DateTime?
  image              String?
  profilePublicId    String?
  password           String
  role               UserRole            @default(MEMBER)
  phone              String?
  address            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  donations          Donation[]
  eventRegistrations EventRegistration[]
  prayerRequests     PrayerRequest[]
  testimonials       Testimonial[]
  eventReports       EventReport[]
  mediaReports       MediaReport[]
  eventsCreated      Event[]             @relation("EventCreator")
  eventMediaUploads  EventMedia[]        @relation("EventMediaUploader")
  donationSessions   DonationSession[]
  receipts           Receipt[]
  notificationLogs   NotificationLog[]
  auditLogs          AuditLog[]
  deviceTokens       DeviceToken[]

  @@map("members")
}

model Event {
  id            String              @id @default(cuid())
  title         String
  description   String
  date          DateTime            @map("event_date")
  time          String              @map("event_time")
  location      String
  image         String?             @map("image_url")
  category      EventCategory
  status        EventStatus         @default(DRAFT)
  isPublished   Boolean             @default(false) @map("is_published")
  branchId      String?             @map("branch_id")
  branch        Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdById   String?             @map("created_by")
  createdBy     User?               @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt
  videoUrl      String?             @map("video_url")
  registrations EventRegistration[]
  media         EventMedia[]
}

model EventMedia {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  imageUrl     String
  publicId     String?  // Cloudinary public_id for deletion
  caption      String?
  uploadedById String?
  uploadedBy   User?    @relation("EventMediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedAt   DateTime @default(now())

  @@index([eventId])
}

model EventRegistration {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Sermon {
  id          String   @id @default(cuid())
  title       String
  description String
  pastor      String
  date        DateTime
  videoUrl          String?
  videoPublicId     String?
  audioUrl          String?
  transcript        String?
  thumbnail         String?
  thumbnailPublicId String?
  category    String
  tags        String[]
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
}

model PrayerRequest {
  id          String         @id @default(cuid())
  userId      String
  title       String
  description String
  category    PrayerCategory
  isAnonymous Boolean        @default(false)
  status      PrayerStatus   @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Donation {
  id                String           @id @default(cuid())
  userId            String?
  amount            Float
  currency          String           @default("INR")
  purpose           String
  purposeId         String?          @map("purpose_id")
  purposeRelation   DonationPurpose? @relation(fields: [purposeId], references: [id])
  branchId          String?          @map("branch_id")
  branch            Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  sessionId         String?          @map("session_id")
  session           DonationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  paymentMethod     String
  stripeId          String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  donorName         String?
  donorEmail        String?
  donorPhone        String?
  status            DonationStatus   @default(PENDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  receipt           Receipt?

  @@map("donations")
}

model Announcement {
  id        String    @id @default(cuid())
  title     String
  content   String
  priority  Priority  @default(NORMAL)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  userId    String
  content   String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ministry {
  id          String   @id @default(cuid())
  name        String
  description String
  leader      String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pastor {
  id        String   @id @default(cuid())
  name      String
  title     String
  bio       String
  image     String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Gallery {
  id           String   @id @default(cuid())
  title        String
  description  String?
  imageUrl     String   @map("image_url")
  thumbnailUrl String?  @map("thumbnail_url")
  category     String
  branchId     String?  @map("branch_id")
  branch       Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([category])
  @@index([branchId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id               String            @id @default(cuid())
  type             String
  title            String
  content          String
  isRead           Boolean           @default(false)
  link             String?
  createdAt        DateTime          @default(now())
  notificationLogs NotificationLog[]

  @@map("notifications")
}

model ChurchSettings {
  id                         String   @id @default("settings")
  churchName                 String
  tagline                    String
  primaryEmail               String
  contactPhone               String
  address                    String
  worshipServices            String
  bilingualSupport           Boolean  @default(true)
  visitorRegistrationEnabled Boolean  @default(true)
  updatedAt                  DateTime @updatedAt
}

model MemberRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  type      String
  time      String
  status    String   @default("New")
  avatar    String?
  createdAt DateTime @default(now())
}

model SmallGroup {
  id            String   @id @default(cuid())
  name          String
  leader        String
  location      String
  meetingTime   String
  attendanceAvg Int      @default(0)
  createdAt     DateTime @default(now())
}

model Volunteer {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  ministry  String
  status    String   @default("Pending")
  appliedAt String
  createdAt DateTime @default(now())
}

model BibleStudy {
  id           String   @id @default(cuid())
  name         String
  leader       String
  time         String
  membersCount Int      @default(0)
  day          String
  createdAt    DateTime @default(now())
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  PASTOR
  MEMBER
  EVENT_MANAGER
  FIELD_VOLUNTEER
  NGO_ADMIN
  BRANCH_MANAGER
  MEDIA_TEAM
}

enum EventCategory {
  WORSHIP
  PRAYER
  YOUTH
  CHILDREN
  WOMEN
  MEN
  SPECIAL
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum PrayerCategory {
  HEALTH
  FAMILY
  FINANCIAL
  SPIRITUAL
  GUIDANCE
  THANKSGIVING
  OTHER
}

enum PrayerStatus {
  PENDING
  PRAYING
  ANSWERED
}

enum DonationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
  REFUNDED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model AttendanceRecord {
  id          String   @id @default(cuid())
  date        DateTime
  serviceType String
  location    String
  headcount   Int
  newVisitors Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pledge {
  id              String       @id @default(cuid())
  donorName       String
  donorEmail      String
  committedAmount Float
  paidAmount      Float        @default(0)
  targetDate      DateTime
  purpose         String
  status          PledgeStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum PledgeStatus {
  PENDING
  ACTIVE
  FULFILLED
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Float
  category    String
  description String
  date        DateTime        @default(now())
  account     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum TransactionType {
  INFLOW
  OUTFLOW
}

model Account {
  id          String   @id @default(cuid())
  name        String   @unique
  balance     Float    @default(0)
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NgoProject {
  id           String         @id @default(cuid())
  title        String
  description  String
  details      String         @db.Text
  imageUrl     String?        // Cover Image URL
  targetAmount Float?
  raisedAmount Float          @default(0)
  status       String         @default("ACTIVE") // ACTIVE, COMPLETED, PLANNED
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  media        NgoMedia[]
  volunteers   NgoVolunteer[]
}

model NgoMedia {
  id           String      @id @default(cuid())
  title        String?
  description  String?
  type         String      // IMAGE, VIDEO_LOCAL, VIDEO_YOUTUBE
  url          String      // File URL, YouTube embed URL, or local path
  publicId     String?     // Cloudinary asset public ID
  thumbnailUrl String?     // Video preview image
  projectId    String?
  project      NgoProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category     String?     // GANDHI-HOSPITAL, GOVT-HOSPITAL, NIMS-HOSPITAL, BETHANY-SAMRAKSHANA, DISABLED-AASHRAMAM
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model NgoVolunteer {
  id        String      @id @default(cuid())
  name      String
  email     String
  phone     String?
  skills    String?     @db.Text
  status    String      @default("PENDING") // PENDING, APPROVED, REJECTED
  projectId String?
  project   NgoProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Branch {
  id               String            @id @default(cuid())
  name             String            @unique // e.g. "Shapur Nagar", "Subhash Nagar", "Bahadurpally"
  createdAt        DateTime          @default(now())
  eventReports     EventReport[]
  events           Event[]
  donationSessions DonationSession[]
  donations        Donation[]
  galleryItems     Gallery[]

  @@map("branches")
}

model EventReport {
  id              String        @id @default(cuid())
  branchId        String
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title           String
  description     String        @db.Text
  attendanceCount Int
  offeringAmount  Float
  reportDate      DateTime
  gpsLocation     String?       // Latitude, Longitude string (e.g. "17.4947, 78.4002")
  volunteerNames  String[]      // List of names of attending volunteers
  status          String        @default("PENDING") // PENDING, APPROVED, REJECTED
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  media           MediaReport[]
}

model MediaReport {
  id            String      @id @default(cuid())
  eventReportId String
  eventReport   EventReport @relation(fields: [eventReportId], references: [id], onDelete: Cascade)
  type          String      // "IMAGE" or "VIDEO"
  url           String      // Storage URL
  thumbnail     String?     // Thumbnail URL
  uploadedById  String
  uploadedBy    User        @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime    @default(now())
}

model Family {
  id                String   @id @default(cuid())
  familyName        String
  headOfHouseholdId String
  members           String[] // List of member User IDs
  contactPhone      String
  address           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ── Church Platform Feedback ─────────────────────────────────────────────────
model ChurchFeedback {
  id          String           @id @default(cuid())
  userId      String?          // nullable for anonymous
  userName    String?          // cached display name
  rating      Int              // 1-5 stars
  category    FeedbackCategory
  comment     String?          @db.Text
  isAnonymous Boolean          @default(false)
  emoji       String?          // optional reaction emoji
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([category])
  @@index([rating])
  @@index([createdAt])
}

enum FeedbackCategory {
  WORSHIP
  SERMONS
  EVENTS
  COMMUNITY
  FACILITIES
  ONLINE_PLATFORM
  LEADERSHIP
  OVERALL
}

model DonationPurpose {
  id               String            @id @default(cuid())
  code             String            @unique
  nameEn           String            @map("name_en")
  nameTe           String            @map("name_te")
  nameHi           String            @map("name_hi")
  descEn           String            @map("desc_en")
  descTe           String?           @map("desc_te")
  descHi           String?           @map("desc_hi")
  sortOrder        Int               @default(0) @map("sort_order")
  isActive         Boolean           @default(true) @map("is_active")
  isArchived       Boolean           @default(false) @map("is_archived")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  donationSessions DonationSession[]
  donations        Donation[]

  @@map("donation_purposes")
}

model DonationSession {
  id                  String               @id @default(cuid())
  memberId            String?              @map("member_id")
  member              User?                @relation(fields: [memberId], references: [id], onDelete: SetNull)
  branchId            String?              @map("branch_id")
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  purposeId           String               @map("purpose_id")
  purpose             DonationPurpose      @relation(fields: [purposeId], references: [id])
  amount              Float
  currency            String               @default("INR")
  referenceNumber     String               @unique @map("reference_number")
  status              DonationStatus       @default(PENDING)
  expiresAt           DateTime             @map("expires_at")
  ipAddress           String?              @map("ip_address")
  device              String?
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  paymentTransactions PaymentTransaction[]
  donations           Donation[]

  @@map("donation_sessions")
}

model PaymentTransaction {
  id        String          @id @default(cuid())
  sessionId String          @map("session_id")
  session   DonationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  utr       String?         @unique
  amount    Float
  currency  String          @default("INR")
  status    String
  gateway   String          @default("UPI_QR")
  payload   Json?
  signature String?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("payment_transactions")
}

model Receipt {
  id               String   @id @default(cuid())
  receiptNumber    String   @unique @map("receipt_number")
  donationId       String   @unique @map("donation_id")
  donation         Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  memberId         String?  @map("member_id")
  member           User?    @relation(fields: [memberId], references: [id], onDelete: SetNull)
  referenceNumber  String?  @map("reference_number")
  amount           Float
  currency         String   @default("INR")
  issuedAt         DateTime @default(now()) @map("issued_at")
  pdfUrl           String?  @map("pdf_url")
  verificationCode String   @unique @map("verification_code")
  qrCode           String?  @map("qr_code")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("receipts")
}

model PaymentWebhook {
  id           String    @id @default(cuid())
  payload      Json
  signature    String?
  ipAddress    String?   @map("ip_address")
  status       String    @default("PENDING")
  errorMessage String?   @map("error_message")
  processedAt  DateTime? @map("processed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("payment_webhooks")
}

model NotificationLog {
  id             String        @id @default(cuid())
  notificationId String?       @map("notification_id")
  notification   Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  recipientId    String?       @map("recipient_id")
  recipient      User?         @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  recipientRole  UserRole?     @map("recipient_role")
  channel        String
  status         String
  errorMessage   String?       @map("error_message")
  sentAt         DateTime      @default(now()) @map("sent_at")

  @@map("notification_logs")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String   @db.Text
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model DeviceToken {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  deviceType String?  @map("device_type")
  platform   String?
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("device_tokens")
}
