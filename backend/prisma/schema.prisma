generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  emailVerified      DateTime?
  image              String?
  profilePublicId    String?
  password           String
  role               UserRole            @default(MEMBER)
  phone              String?
  address            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  donations          Donation[]
  eventRegistrations EventRegistration[]
  prayerRequests     PrayerRequest[]
  testimonials       Testimonial[]
  eventReports       EventReport[]
  mediaReports       MediaReport[]
  eventsCreated      Event[]             @relation("EventCreator")
  eventMediaUploads  EventMedia[]        @relation("EventMediaUploader")
  deviceTokens       DeviceToken[]
  auditLogs          AuditLog[]
}

model Event {
  id            String              @id @default(cuid())
  title         String
  description   String
  date          DateTime
  time          String
  location      String
  image         String?
  category      EventCategory
  status        EventStatus         @default(DRAFT)
  branchId      String?
  branch        Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?               @relation("EventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  registrations EventRegistration[]
  media         EventMedia[]
}

model EventMedia {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  imageUrl     String
  publicId     String?  // Cloudinary public_id for deletion
  caption      String?
  uploadedById String?
  uploadedBy   User?    @relation("EventMediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedAt   DateTime @default(now())

  @@index([eventId])
}

model EventRegistration {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Sermon {
  id          String   @id @default(cuid())
  title       String
  description String
  pastor      String
  date        DateTime
  videoUrl          String?
  videoPublicId     String?
  audioUrl          String?
  transcript        String?
  thumbnail         String?
  thumbnailPublicId String?
  category    String
  tags        String[]
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
}

model PrayerRequest {
  id          String         @id @default(cuid())
  userId      String
  title       String
  description String
  category    PrayerCategory
  isAnonymous Boolean        @default(false)
  status      PrayerStatus   @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Donation {
  id                String          @id @default(cuid())
  userId            String?
  amount            Float
  currency          String          @default("INR")
  purpose           DonationPurpose
  paymentMethod     String
  stripeId          String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  donorName         String?
  donorEmail        String?
  donorPhone        String?
  status            DonationStatus  @default(PENDING)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User?           @relation(fields: [userId], references: [id])
}

model Announcement {
  id        String    @id @default(cuid())
  title     String
  content   String
  priority  Priority  @default(NORMAL)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  userId    String
  content   String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ministry {
  id          String   @id @default(cuid())
  name        String
  description String
  leader      String
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pastor {
  id        String   @id @default(cuid())
  name      String
  title     String
  bio       String
  image     String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Gallery {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  content   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model ChurchSettings {
  id                         String   @id @default("settings")
  churchName                 String
  tagline                    String
  primaryEmail               String
  contactPhone               String
  address                    String
  worshipServices            String
  bilingualSupport           Boolean  @default(true)
  visitorRegistrationEnabled Boolean  @default(true)
  updatedAt                  DateTime @updatedAt
}

model MemberRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  type      String
  time      String
  status    String   @default("New")
  avatar    String?
  createdAt DateTime @default(now())
}

model SmallGroup {
  id            String   @id @default(cuid())
  name          String
  leader        String
  location      String
  meetingTime   String
  attendanceAvg Int      @default(0)
  createdAt     DateTime @default(now())
}

model Volunteer {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  ministry  String
  status    String   @default("Pending")
  appliedAt String
  createdAt DateTime @default(now())
}

model BibleStudy {
  id           String   @id @default(cuid())
  name         String
  leader       String
  time         String
  membersCount Int      @default(0)
  day          String
  createdAt    DateTime @default(now())
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  PASTOR
  MEMBER
  EVENT_MANAGER
  FIELD_VOLUNTEER
  NGO_ADMIN
  BRANCH_MANAGER
  MEDIA_TEAM
}

enum EventCategory {
  WORSHIP
  PRAYER
  YOUTH
  CHILDREN
  WOMEN
  MEN
  SPECIAL
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum PrayerCategory {
  HEALTH
  FAMILY
  FINANCIAL
  SPIRITUAL
  GUIDANCE
  THANKSGIVING
  OTHER
}

enum PrayerStatus {
  PENDING
  PRAYING
  ANSWERED
}

enum DonationPurpose {
  GENERAL
  BUILDING
  MISSIONS
  YOUTH
  CHARITY
  TITHE
  OFFERING
  OTHER
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model AttendanceRecord {
  id          String   @id @default(cuid())
  date        DateTime
  serviceType String
  location    String
  headcount   Int
  newVisitors Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pledge {
  id              String       @id @default(cuid())
  donorName       String
  donorEmail      String
  committedAmount Float
  paidAmount      Float        @default(0)
  targetDate      DateTime
  purpose         String
  status          PledgeStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum PledgeStatus {
  PENDING
  ACTIVE
  FULFILLED
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Float
  category    String
  description String
  date        DateTime        @default(now())
  account     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum TransactionType {
  INFLOW
  OUTFLOW
}

model Account {
  id          String   @id @default(cuid())
  name        String   @unique
  balance     Float    @default(0)
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NgoProject {
  id           String         @id @default(cuid())
  title        String
  description  String
  details      String         @db.Text
  imageUrl     String?        // Cover Image URL
  targetAmount Float?
  raisedAmount Float          @default(0)
  status       String         @default("ACTIVE") // ACTIVE, COMPLETED, PLANNED
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  media        NgoMedia[]
  volunteers   NgoVolunteer[]
}

model NgoMedia {
  id           String      @id @default(cuid())
  title        String?
  description  String?
  type         String      // IMAGE, VIDEO_LOCAL, VIDEO_YOUTUBE
  url          String      // File URL, YouTube embed URL, or local path
  publicId     String?     // Cloudinary asset public ID
  thumbnailUrl String?     // Video preview image
  projectId    String?
  project      NgoProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category     String?     // GANDHI-HOSPITAL, GOVT-HOSPITAL, NIMS-HOSPITAL, BETHANY-SAMRAKSHANA, DISABLED-AASHRAMAM
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model NgoVolunteer {
  id        String      @id @default(cuid())
  name      String
  email     String
  phone     String?
  skills    String?     @db.Text
  status    String      @default("PENDING") // PENDING, APPROVED, REJECTED
  projectId String?
  project   NgoProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Branch {
  id           String        @id @default(cuid())
  name         String        @unique // e.g. "Shapur Nagar", "Subhash Nagar", "Bahadurpally"
  createdAt    DateTime      @default(now())
  eventReports EventReport[]
  events       Event[]
}

model EventReport {
  id              String        @id @default(cuid())
  branchId        String
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title           String
  description     String        @db.Text
  attendanceCount Int
  offeringAmount  Float
  reportDate      DateTime
  gpsLocation     String?       // Latitude, Longitude string (e.g. "17.4947, 78.4002")
  volunteerNames  String[]      // List of names of attending volunteers
  status          String        @default("PENDING") // PENDING, APPROVED, REJECTED
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  media           MediaReport[]
}

model MediaReport {
  id            String      @id @default(cuid())
  eventReportId String
  eventReport   EventReport @relation(fields: [eventReportId], references: [id], onDelete: Cascade)
  type          String      // "IMAGE" or "VIDEO"
  url           String      // Storage URL
  thumbnail     String?     // Thumbnail URL
  uploadedById  String
  uploadedBy    User        @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime    @default(now())
}

model DeviceToken {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  deviceType  String?  // web, android, ios
  platform    String?  // browser, native
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // EVENT_CREATED, MEDIA_UPLOADED, SECURITY_ALERT, PUSH_SENT
  details    String   @db.Text
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
}

